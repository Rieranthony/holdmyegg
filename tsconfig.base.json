{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@out-of-bounds/map": [
        "packages/map/src/index.ts"
      ],
      "@out-of-bounds/sim": [
        "packages/sim/src/index.ts"
      ],
      "@test/*": [
        "test/*"
      ]
    }
  }
}
