{
  "name": "out-of-bounds",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "dev": "bun apps/server/src/devLauncher.ts",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "bun run --cwd apps/server dev",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mechanics": "vitest run --project map --project sim",
    "test:server": "vitest run --project netcode --project db --project server",
    "test:web": "vitest run --project web",
    "test": "vitest run",
    "build": "bun run --workspaces build",
    "check": "bun run test && bun run build"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "fake-indexeddb": "^6.2.4",
    "jsdom": "^27.0.1",
    "vitest": "^4.1.2"
  }
}
